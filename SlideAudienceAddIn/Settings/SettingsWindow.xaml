<Window x:Class="SlideAudienceAddIn.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SlideAudience Settings"
        Width="520"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="SlideAudience Settings"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,18" />

        <StackPanel Grid.Row="1">
            <CheckBox x:Name="EnableAddInCheckBox"
                      Content="Enable comments during slide show"
                      Margin="0,0,0,16" />

            <GroupBox Header="Gemini" Margin="0,0,0,16" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Use API" VerticalAlignment="Center" />
                    <CheckBox x:Name="EnableApiCheckBox" Grid.Column="1" />

                    <TextBlock Grid.Row="1" Text="Model" Margin="0,12,0,0" VerticalAlignment="Center" />
                    <TextBox x:Name="ModelTextBox" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" />

                    <TextBlock Grid.Row="2" Text="Timeout seconds" Margin="0,12,0,0" VerticalAlignment="Center" />
                    <TextBox x:Name="TimeoutTextBox" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" />
                </Grid>
            </GroupBox>

            <GroupBox Header="Comments" Margin="0,0,0,16" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Mode" VerticalAlignment="Center" />
                    <ComboBox x:Name="ModeComboBox" Grid.Column="1">
                        <ComboBoxItem Content="Mixed" />
                        <ComboBoxItem Content="UnderstandingOnly" />
                        <ComboBoxItem Content="InterestOnly" />
                        <ComboBoxItem Content="CriticalOnly" />
                    </ComboBox>

                    <TextBlock Grid.Row="1" Text="Max comments" Margin="0,12,0,0" VerticalAlignment="Center" />
                    <ComboBox x:Name="MaxCommentsComboBox" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                        <ComboBoxItem Content="1" />
                        <ComboBoxItem Content="2" />
                        <ComboBoxItem Content="3" />
                    </ComboBox>

                    <TextBlock Grid.Row="2" Text="Font size" Margin="0,12,0,0" VerticalAlignment="Center" />
                    <TextBox x:Name="FontSizeTextBox" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" />

                    <TextBlock Grid.Row="3" Text="Position" Margin="0,12,0,0" VerticalAlignment="Center" />
                    <ComboBox x:Name="PositionComboBox" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0">
                        <ComboBoxItem Content="BottomRight" />
                        <ComboBoxItem Content="BottomLeft" />
                        <ComboBoxItem Content="TopRight" />
                        <ComboBoxItem Content="TopLeft" />
                    </ComboBox>
                </Grid>
            </GroupBox>

            <GroupBox Header="Experiment Log" Padding="14">
                <StackPanel>
                    <CheckBox x:Name="EnableLoggingCheckBox"
                              Content="Save JSONL logs"
                              Margin="0,0,0,10" />
                    <CheckBox x:Name="SaveSlideTextCheckBox"
                              Content="Include extracted slide text in logs" />
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Width="96"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click" />
            <Button Content="Save"
                    Width="96"
                    IsDefault="True"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
